---
interface Props {
  volatility?: string;
  class?: string;
}

const { volatility, class: className } = Astro.props;

const config: Record<string, { text: string; classes: string }> = {
  low: { text: 'Stable', classes: 'bg-green-50 text-green-700 ring-green-600/20' },
  stable: { text: 'Stable', classes: 'bg-green-50 text-green-700 ring-green-600/20' },
  moderate: { text: 'May change', classes: 'bg-amber-50 text-amber-700 ring-amber-600/20' },
  medium: { text: 'May change', classes: 'bg-amber-50 text-amber-700 ring-amber-600/20' },
  high: { text: 'Changes often', classes: 'bg-red-50 text-red-700 ring-red-600/20' },
};

const badge = volatility ? config[volatility] : null;
---

{badge && (
  <span class:list={["inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset", badge.classes, className]}>
    {badge.text}
  </span>
)}
