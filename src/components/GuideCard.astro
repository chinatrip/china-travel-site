---
import Badge from './Badge.astro';

interface Props {
  title: string;
  href: string;
  volatility?: string;
  lastVerified?: string;
}

const { title, href, volatility, lastVerified } = Astro.props;

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return dateStr;
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<a href={href} class="group block rounded-lg border border-gray-200 p-5 transition-all hover:shadow-md hover:-translate-y-0.5 hover:border-gray-300 bg-white">
  <div class="flex items-start justify-between gap-3">
    <h3 class="font-semibold text-gray-900 group-hover:text-primary transition-colors leading-snug">
      {title}
    </h3>
    <Badge volatility={volatility} />
  </div>
  {lastVerified && (
    <p class="mt-2 text-xs text-muted">
      Verified {formatDate(lastVerified)}
    </p>
  )}
</a>
