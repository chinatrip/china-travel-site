---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuideCard from '../../components/GuideCard.astro';
import { getCollection } from 'astro:content';

const apps = await getCollection('apps', ({ data }) => data.status === 'audited');
---

<BaseLayout title="Essential Apps" description="Must-have apps for foreigners in China — payments, navigation, transport, and daily life.">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-secondary mb-2">Essential Apps</h1>
      <p class="text-muted text-lg">Apps you should download before arriving in China.</p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {apps.map((app) => (
        <GuideCard
          title={app.data.title}
          href={`/apps/${app.id}`}
          volatility={app.data.volatility}
          lastVerified={app.data.last_verified}
        />
      ))}
    </div>
  </div>
</BaseLayout>
