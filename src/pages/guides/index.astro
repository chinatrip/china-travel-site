---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const guides = await getCollection('guides', ({ data }) => data.status === 'audited');
---

<BaseLayout title="Travel Guides" description="Practical guides for foreigners traveling in China — visa, payments, transport, safety, and more.">
  <h1>Travel Guides</h1>
  <p class="subtitle">Everything you need to know before and during your trip to China.</p>
  <ul class="guide-list">
    {guides.map((guide) => (
      <li>
        <a href={`/guides/${guide.id}`}>
          <strong>{guide.data.title}</strong>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: #6b7280;
    margin-bottom: 2rem;
  }

  .guide-list {
    list-style: none;
    padding: 0;
  }

  .guide-list li {
    border-bottom: 1px solid #e5e7eb;
  }

  .guide-list a {
    display: block;
    padding: 1rem 0;
    text-decoration: none;
    color: #1a56db;
  }

  .guide-list a:hover {
    background: #f9fafb;
    margin: 0 -1rem;
    padding: 1rem;
  }
</style>
