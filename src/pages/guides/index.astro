---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuideCard from '../../components/GuideCard.astro';
import { getCollection } from 'astro:content';

const guides = await getCollection('guides', ({ data }) => data.status === 'audited');
---

<BaseLayout title="Travel Guides" description="Practical guides for foreigners traveling in China — visa, payments, transport, safety, and more.">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-secondary mb-2">Travel Guides</h1>
      <p class="text-muted text-lg">Everything you need to know before and during your trip to China.</p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {guides.map((guide) => (
        <GuideCard
          title={guide.data.title}
          href={`/guides/${guide.id}`}
          volatility={guide.data.volatility}
          lastVerified={guide.data.last_verified}
        />
      ))}
    </div>
  </div>
</BaseLayout>
