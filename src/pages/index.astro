---
import BaseLayout from '../layouts/BaseLayout.astro';
import GuideCard from '../components/GuideCard.astro';
import { getCollection } from 'astro:content';

const guides = await getCollection('guides', ({ data }) => data.status === 'audited');
const apps = await getCollection('apps', ({ data }) => data.status === 'audited');
const totalGuides = guides.length + apps.length;
---

<BaseLayout title="China Travel Guide for Foreigners" description="Practical travel guides for foreigners visiting China — visa, mobile payment, apps, transportation, food, and safety. Verified from official sources, updated 2026.">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-secondary to-blue-900 text-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
      <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-4">
        Your practical guide to<br />
        <span class="text-red-400">traveling in China</span>
      </h1>
      <p class="text-lg sm:text-xl text-blue-200 max-w-2xl mb-8">
        Everything foreigners need to know — visa, payments, apps, transport, and more. Verified by real travelers, updated regularly.
      </p>

      <div class="flex flex-wrap gap-6 text-sm text-blue-200">
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 bg-green-400 rounded-full"></span>
          {totalGuides} verified guides
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 bg-green-400 rounded-full"></span>
          Updated weekly
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 bg-green-400 rounded-full"></span>
          Cited from official sources
        </div>
      </div>
    </div>
  </section>

  <!-- Guides Section -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-secondary">Travel Guides</h2>
      <a href="/guides" class="text-sm text-primary font-medium hover:underline">View all &rarr;</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {guides.map((guide) => (
        <GuideCard
          title={guide.data.title}
          href={`/guides/${guide.id}`}
          lastVerified={guide.data.last_verified}
        />
      ))}
    </div>
  </section>

  <!-- Apps Section -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-secondary">Essential Apps</h2>
      <a href="/apps" class="text-sm text-primary font-medium hover:underline">View all &rarr;</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {apps.map((app) => (
        <GuideCard
          title={app.data.title}
          href={`/apps/${app.id}`}
          lastVerified={app.data.last_verified}
        />
      ))}
    </div>
  </section>
</BaseLayout>
